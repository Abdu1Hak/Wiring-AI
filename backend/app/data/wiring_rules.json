        "label": "PWM Signal"
      },
      {
        "from": "arduino_uno.5v",
        "to": "servo.vcc",
        "type": "power",
        "label": "Power"
      },
      {
        "from": "servo.gnd",
        "to": "arduino_uno.gnd1",
        "type": "ground",
        "label": "Ground"
      }
    ]
  },

  {
    "id": "arduino_dht11",
    "requires": ["arduino_uno", "dht11"],
