        "to": "buzzer.positive",
        "type": "signal",
        "label": "Buzzer Signal"
      },
      {
        "from": "buzzer.negative",
        "to": "arduino_uno.gnd1",
        "type": "ground",
        "label": "Ground"
      }
    ]
  },

  {
    "id": "arduino_servo",
