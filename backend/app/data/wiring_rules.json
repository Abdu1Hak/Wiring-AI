[
  {
    "id": "arduino_hc_sr04",
    "requires": ["arduino_uno", "hc_sr04"],
    "connections": [
      {
        "from": "arduino_uno.5v",
        "to": "hc_sr04.vcc",
        "type": "power",
        "label": "Power"
      },
      {
        "from": "arduino_uno.gnd1",
        "to": "hc_sr04.gnd",
        "type": "ground",
        "label": "Ground"
      },
      {
        "from": "arduino_uno.d9",
        "to": "hc_sr04.trig",
        "type": "signal",
        "label": "Trigger"
      },
      {
        "from": "hc_sr04.echo",
        "to": "arduino_uno.d10",
        "type": "signal",
        "label": "Echo"
      }
    ]
  },

  {
    "id": "arduino_led_resistor",
    "requires": ["arduino_uno", "led", "resistor"],
    "connections": [
      {
        "from": "arduino_uno.d13",
        "to": "resistor.terminal1",
        "type": "signal",
        "label": "LED Signal"
      },
      {
        "from": "resistor.terminal2",
        "to": "led.anode",
        "type": "signal",
        "label": "Current Limiting"
      },
      {
        "from": "led.cathode",
        "to": "arduino_uno.gnd1",
        "type": "ground",
        "label": "Ground"
      }
    ]
  },

  {
    "id": "arduino_buzzer",
