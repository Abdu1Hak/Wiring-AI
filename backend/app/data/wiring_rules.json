  {
    "id": "arduino_push_button_resistor",
    "requires": ["arduino_uno", "push_button", "resistor"],
    "connections": [
      {
        "from": "arduino_uno.5v",
        "to": "push_button.a1",
        "type": "power",
        "label": "Button Power"
      },
      {
        "from": "push_button.b1",
        "to": "arduino_uno.d2",
        "type": "signal",
        "label": "Button Signal"
      },
      {
        "from": "push_button.b1",
        "to": "resistor.terminal1",
        "type": "signal",
